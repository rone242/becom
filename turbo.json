{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "DIRECT_URL",
    "JWT_SECRET",
    "CLOUDINARY_CLOUD_NAME",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WHATSAPP_NUMBER",
    "REDIS_URL",
    "INTERNAL_API_KEY",
    "VIP_PURCHASE_MILESTONE",
    "INTEGRATION_CACHE_TTL",
    "PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "edge:dev": {
      "cache": false,
      "persistent": true
    },
    "edge:deploy": {
      "cache": false
    },
    "edge:typecheck": {
      "outputs": []
    }
  }
}
