# ============================================================
#  Becom Monorepo — .gitignore
#  Standard: Node.js + Next.js + NestJS + Prisma + Turborepo
#  Last updated: 2025
# ============================================================


# ─── Environment Variables ────────────────────────────────────────────────────
# NEVER commit secrets, API keys, or credentials to Git.
.env
.env.*
!.env.example
!.env.*.example


# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions


# ─── Build Outputs ───────────────────────────────────────────────────────────
dist/
build/
out/
*.tsbuildinfo


# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
next-env.d.ts


# ─── NestJS ──────────────────────────────────────────────────────────────────
# dist/ already covered above


# ─── Turborepo ───────────────────────────────────────────────────────────────
.turbo/


# ─── Prisma ──────────────────────────────────────────────────────────────────
# Keep schema.prisma and migrations tracked.
# Ignore generated client files (regenerated during build).
packages/database/node_modules/


# ─── TypeScript ──────────────────────────────────────────────────────────────
*.js.map
*.d.ts.map


# ─── Testing ─────────────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/
jest-results/
playwright-report/
test-results/


# ─── Docker ──────────────────────────────────────────────────────────────────
# Keep docker-compose.yml and Dockerfiles tracked.
# Ignore local Docker override files.
docker-compose.override.yml
docker-compose.local.yml


# ─── Cloudflare Workers (analytics-router/edge) ──────────────────────────────
apps/analytics-router/edge/.dev.vars
apps/analytics-router/edge/dist/
apps/analytics-router/edge/.wrangler/
.wrangler/


# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
*.log.*


# ─── OS Files ────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ─── Editors & IDEs ──────────────────────────────────────────────────────────
# VS Code — keep shared settings, ignore personal/workspace files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist

# Sublime Text
*.sublime-project
*.sublime-workspace

# Emacs
\#*\#
*.elc
auto-save-list


# ─── Misc ────────────────────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz
*.tar.gz
*.zip
tmp/
temp/
