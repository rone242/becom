{
  "name": "@becom/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
  "prebuild": "npx prisma generate --schema=../../packages/database/prisma/schema.prisma",
  "build": "nest build",
  "dev": "nest start --watch",
  "start": "node dist/main",
  "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
  "db:generate": "cd ../../packages/database && npx prisma generate",
  "db:migrate": "cd ../../packages/database && npx prisma migrate dev",
  "db:push": "cd ../../packages/database && npx prisma db push"
  },
  "dependencies": {
    "@becom/database": "*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "@aws-sdk/client-s3": "^3.600.0",
    "cookie-parser": "^1.4.6",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "slugify": "^1.6.6",
    "sharp": "^0.33.5",
    "swiper": "12.1.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/streamifier": "^0.1.2",
    "typescript": "^5.4.5"
  }
}
