# ──────────────────────────────────────────────────────────────
# Analytics Router — Environment Variables
# Copy to .env and fill in your actual values
# ──────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4001

# ── Database (shared Neon DB, same as main API) ───────────────
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL="redis://:yourpassword@localhost:6379"

# ── Security ──────────────────────────────────────────────────
# Internal API key — the Next.js frontend must send this in X-Internal-Key header
INTERNAL_API_KEY="change-me-to-a-secure-random-string"

# JWT secret (same as main API, for admin auth on /admin/* routes)
JWT_SECRET="your-jwt-secret"

# ── VIP Milestone ─────────────────────────────────────────────
# Number of successful 'Purchase' events before a user is upgraded to VIP
VIP_PURCHASE_MILESTONE=10

# ── Redis Cache TTL (seconds) ─────────────────────────────────
INTEGRATION_CACHE_TTL=3600

# ── Cloudflare Worker Edge Layer ──────────────────────────────
# The public URL of this NestJS analytics-router service.
# The Cloudflare Worker forwards validated events to this URL.
# Set as a wrangler secret: npx wrangler secret put ORIGIN_URL
# For local dev, set in apps/analytics-router/edge/.dev.vars
ORIGIN_URL="https://analytics.yourdomain.com"

