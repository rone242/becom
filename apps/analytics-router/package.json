{
  "name": "@becom/analytics-router",
  "version": "0.0.1",
  "private": true,
  "description": "Event Analytics Router Microservice — routes frontend events to third-party platforms via BullMQ with Redis-first counters",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "edge:dev": "cd edge && npx wrangler dev",
    "edge:deploy": "cd edge && npx wrangler deploy",
    "edge:typecheck": "cd edge && npx tsc --noEmit"
  },
  "dependencies": {
    "@becom/database": "*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.4.5"
  }
}
