# ==============================================================================
# 🚀 BECOM MONOREPO — ENVIRONMENT VARIABLES
# Copy this file to `.env` in the root, and also inside respective apps if needed.
#
# PRODUCTION INFRASTRUCTURE:
#   - Database : Neon DB (serverless PostgreSQL)  → neon.tech
#   - Redis    : Upstash Redis (serverless Redis) → upstash.com
#   - API      : Railway                          → railway.app
#   - Web      : Railway                          → railway.app
#   - Analytics: Railway                          → railway.app
#   - Edge     : Cloudflare Workers               → cloudflare.com
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 🌍 GLOBAL / SHARED
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV="development" # Set to "production" in production

# ── Neon DB (PostgreSQL) ─────────────────────────────────────────────────────
# Get both URLs from: Neon Dashboard → Your Project → Connection Details
#
# DATABASE_URL   = Pooled URL (via PgBouncer) — for runtime queries
# DIRECT_URL     = Direct URL (non-pooled)    — for Prisma migrations ONLY
#
# Production format:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/becom?sslmode=require&pgbouncer=true&connect_timeout=10"
#   DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/becom?sslmode=require&connect_timeout=10"
#
# Local development:
DATABASE_URL="postgresql://postgres:password@localhost:5432/becom"
DIRECT_URL="postgresql://postgres:password@localhost:5432/becom"

# ── Upstash Redis ────────────────────────────────────────────────────────────
# Get from: Upstash Console → Your Database → REST API or ioredis
#
# Production format (TLS — note rediss:// with double 's'):
#   REDIS_URL="rediss://default:your-password@xxx.upstash.io:6379"
#
# Local development:
REDIS_URL="redis://localhost:6379"

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 48
JWT_SECRET="your-super-secret-jwt-key"

# ──────────────────────────────────────────────────────────────────────────────
# 🌐 NEXT.JS WEB APP (`apps/web`)
# ──────────────────────────────────────────────────────────────────────────────

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 48
NEXTAUTH_SECRET="your-nextauth-secret-key"

# API URLs — NEXT_PUBLIC_* are baked into the build at Docker build time
# Set these to your Railway service public URLs in production:
#   NEXT_PUBLIC_API_URL="https://becom-api.up.railway.app/api"
#   NEXT_PUBLIC_ANALYTICS_ROUTER_URL="https://becom-analytics.up.railway.app/api"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_ANALYTICS_ROUTER_URL="http://localhost:4001/api"

# Server-side URLs (used during SSR — use Railway internal URLs in production)
# In Railway, services on the same project communicate via private networking:
#   SERVER_API_URL="http://becom-api.railway.internal/api"
#   SERVER_ANALYTICS_ROUTER_URL="http://becom-analytics.railway.internal/api"
SERVER_API_URL="http://localhost:4000/api"
SERVER_ANALYTICS_ROUTER_URL="http://localhost:4001/api"

# Contact
NEXT_PUBLIC_WHATSAPP_NUMBER="8801712345678"

# Analytics (Optional)
NEXT_PUBLIC_GTM_ID=""

# ──────────────────────────────────────────────────────────────────────────────
# ⚙️ NESTJS API (`apps/api`)
# ──────────────────────────────────────────────────────────────────────────────
PORT="4000"
FRONTEND_URL="http://localhost:3000"

# Cloudflare R2 (for image uploads)
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="becom-assets"
R2_PUBLIC_URL="https://assets.yourdomain.com" # Or your *.r2.dev URL

# ──────────────────────────────────────────────────────────────────────────────
# 📊 ANALYTICS ROUTER (`apps/analytics-router`)
# ──────────────────────────────────────────────────────────────────────────────

# Internal Security — shared between the Cloudflare Worker and the NestJS origin
# Generate: openssl rand -base64 32
INTERNAL_API_KEY="change-me-to-a-secure-random-string"

# Logic Configuration
VIP_PURCHASE_MILESTONE="10"
INTEGRATION_CACHE_TTL="3600"

# Origin URL for the Cloudflare Worker to forward validated events to
# In production: your Railway analytics-router public URL
ORIGIN_URL="http://localhost:4001"

# ──────────────────────────────────────────────────────────────────────────────
# ☁️ CLOUDFLARE WORKER (`apps/analytics-router/edge`)
# ──────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN="2a91da8e1fb44fa084d2d21141572011"

# ──────────────────────────────────────────────────────────────────────────────
# 🚂 RAILWAY (CI/CD — GitHub Actions secrets only, NOT in .env files)
# ──────────────────────────────────────────────────────────────────────────────
# RAILWAY_TOKEN="your-railway-token"
# RAILWAY_API_SERVICE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# RAILWAY_WEB_SERVICE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# RAILWAY_ANALYTICS_SERVICE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# ANALYTICS_ORIGIN_URL="https://becom-analytics.up.railway.app"
