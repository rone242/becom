# ==============================================================================
# 🚀 BECOM MONOREPO — ENVIRONMENT VARIABLES
# Copy this file to `.env` in the root, and also inside respective apps if needed.
# For production Docker deployments, these variables are often set in the VPS `.env`
# or passed via GitHub Actions secrets.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 🌍 GLOBAL / SHARED
# ──────────────────────────────────────────────────────────────────────────────
NODE_ENV="development" # Set to "production" in production

# Database (PostgreSQL via Prisma)
# Used by: api, analytics-router
DATABASE_URL="postgresql://postgres:password@localhost:5432/becom"
DIRECT_URL="postgresql://postgres:password@localhost:5432/becom"

# Redis
# Used by: api, analytics-router
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"

# JWT Authentication
# Used by: api, analytics-router
# Generate a strong secret: `openssl rand -base64 48`
JWT_SECRET="your-super-secret-jwt-key"

# ──────────────────────────────────────────────────────────────────────────────
# 🌐 NEXT.JS WEB APP (`apps/web/.env`)
# ──────────────────────────────────────────────────────────────────────────────

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
# Generate a strong secret: `openssl rand -base64 48`
NEXTAUTH_SECRET="your-nextauth-secret-key"

# API URLs (Frontend client-side calls)
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
NEXT_PUBLIC_ANALYTICS_ROUTER_URL="http://localhost:4001/api"

# API URLs (Server-side calls during SSR)
# In Docker, use the internal network names (e.g., http://becom-api:4000/api)
SERVER_API_URL="http://localhost:4000/api"
SERVER_ANALYTICS_ROUTER_URL="http://localhost:4001/api"

# Contact
NEXT_PUBLIC_WHATSAPP_NUMBER="8801712345678"

# Analytics (Optional)
NEXT_PUBLIC_GTM_ID=""

# ──────────────────────────────────────────────────────────────────────────────
# ⚙️ NESTJS API (`apps/api/.env`)
# ──────────────────────────────────────────────────────────────────────────────
PORT="4000"
FRONTEND_URL="http://localhost:3000"

# Cloudinary (for image uploads)
# Get these from cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ──────────────────────────────────────────────────────────────────────────────
# 📊 ANALYTICS ROUTER (`apps/analytics-router/.env`)
# ──────────────────────────────────────────────────────────────────────────────
# Note: PORT 5001 is used internally in Docker, mapped to 4001 externally
# PORT="5001" # Usually set in docker-compose

# Internal Security
# Must match exactly between Next.js (if it calls directly) and the Edge Worker
INTERNAL_API_KEY="change-me-to-a-secure-random-string"

# Logic Configuration
VIP_PURCHASE_MILESTONE="10"
INTEGRATION_CACHE_TTL="3600"

# Origin URL for the Edge Worker (Not strictly needed in the NestJS app itself, 
# but used by the Cloudflare Worker to know where to forward requests)
ORIGIN_URL="http://localhost:4001"
